{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Veronica",
  "version": "1.0.0",
  "identifier": "com.veronica.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Veronica",
        "width": 140,
        "height": 140,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "acceptFirstMouse": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "shadow": false,
        "center": true,
        "visible": true,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0"
    }
  }
}
