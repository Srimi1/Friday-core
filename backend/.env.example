# Veronica Backend — environment variables
# Copy to .env and fill in your keys

# ── LLM ───────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here       # Gemini 2.5 Flash (default LLM)
OPENAI_API_KEY=your_openai_api_key_here       # GPT-4o fallback + OpenAI TTS

# ── Voice (LiveKit pipeline) ───────────────────────────
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── STT/TTS ────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key            # Sarvam STT (saaras:v3) + TTS (bulbul:v3)
DEEPGRAM_API_KEY=your_deepgram_api_key        # Deepgram Aura TTS (default TTS)

# ── Optional ───────────────────────────────────────────
SERVER_NAME=Friday                            # MCP server display name
DEBUG=false
BRIDGE_PORT=8001                              # HTTP bridge port (Rust calls this)
